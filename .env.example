# =========================================================================
# APPLICATION CONFIGURATION (TEMPLATE)
# =========================================================================
# INSTRUCTIONS:
# 1. BASE CONFIG (.env): Copy variables from BLOCK #1.
#    This is for local development (npm run dev).
# 2. DOCKER CONFIG (.env.prod): Copy variables from BLOCK #2.
#    These will override base values when running via Docker.
# =========================================================================



# ---------------------------------------------------------
# BLOCK #1: COMMON & LOCAL BASE (Keep these in your .env)
# ---------------------------------------------------------

# Application mode: dev | prod
MODE=dev

# System domain (SEO & Absolute Links)
NEXT_PUBLIC_SITE=qucore.vercel.app

# Google Console code
NEXT_PUBLIC_GOOGLE_CONSOLE_CODE=1234567890



# ---------------------------------------------------------
# BLOCK #2: DOCKER OVERRIDES (Keep these in your .env.prod)
# ---------------------------------------------------------

# These values will override the ones above inside the container
MODE=prod